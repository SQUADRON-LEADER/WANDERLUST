<% layout("/layouts/boilerplate") %>

<% layout("/layouts/boilerplate") %>

<style>
.login-container {
    background: #ffffff;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: -20px -15px;
    padding: 20px;
}

.login-card {
    background: #ffffff;
    border-radius: 15px;
    padding: 40px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    border: 1px solid #e9ecef;
    max-width: 450px;
    width: 100%;
}

.login-header {
    text-align: center;
    margin-bottom: 30px;
}

.login-header h3 {
    color: #2c3e50;
    font-weight: 700;
    margin-bottom: 10px;
    font-size: 2rem;
}

.login-header p {
    color: #6c757d;
    margin: 0;
}

.form-control {
    border-radius: 8px;
    border: 1px solid #dee2e6;
    padding: 12px 16px;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: #ffffff;
}

.form-control:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.15);
    background: #ffffff;
}

.form-label {
    font-weight: 600;
    color: #2c3e50;
    margin-bottom: 8px;
}

.login-btn {
    background: #667eea;
    border: none;
    border-radius: 8px;
    padding: 12px 24px;
    font-size: 1.1rem;
    font-weight: 600;
    width: 100%;
    color: white;
    transition: all 0.3s ease;
}

.login-btn:hover {
    background: #5a67d8;
    transform: translateY(-1px);
}

.forgot-password {
    text-align: center;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #e9ecef;
}

.forgot-password a {
    color: #667eea;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
}

.forgot-password a:hover {
    color: #5a67d8;
    text-decoration: underline;
}

.signup-link {
    text-align: center;
    margin-top: 15px;
    color: #6c757d;
}

.signup-link a {
    color: #667eea;
    font-weight: 600;
    text-decoration: none;
}

.signup-link a:hover {
    color: #5a67d8;
    text-decoration: underline;
}

.demo-credentials {
    background: #f8f9fa;
    border: 1px solid #e9ecef;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 20px;
    text-align: center;
}

.demo-credentials h6 {
    color: #495057;
    margin-bottom: 10px;
    font-weight: 600;
}

.demo-credentials p {
    margin: 5px 0;
    font-size: 0.9rem;
    color: #6c757d;
}

.demo-credentials .cred {
    background: #ffffff;
    border: 1px solid #dee2e6;
    border-radius: 4px;
    padding: 5px 10px;
    margin: 2px;
    display: inline-block;
    font-family: monospace;
    color: #495057;
}

@media (max-width: 576px) {
    .login-card {
        margin: 20px;
        padding: 30px 20px;
    }
}
</style>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h3><i class="fa-solid fa-key"></i> Welcome Back!</h3>
            <p>Login to your Wanderlust account</p>
        </div>
        
        <div class="demo-credentials">
            <h6><i class="fa-solid fa-info-circle"></i> Demo Login Credentials</h6>
            <p>Username: <span class="cred">demo</span> | Password: <span class="cred">password123</span></p>
            <p><small>Or create a new account below</small></p>
        </div>
        
        <form action="/login" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" class="form-label">
                    <i class="fa-solid fa-user"></i> Username
                </label>
                <input name="username" id="username" placeholder="Enter your username" type="text" class="form-control" required>
                <div class="valid-feedback">Username looks good!</div>
                <div class="invalid-feedback">Please provide a valid username.</div>
            </div>
            
            <div class="mb-3">
                <label for="password" class="form-label">
                    <i class="fa-solid fa-lock"></i> Password
                </label>
                <input name="password" id="password" placeholder="Enter your password" type="password" class="form-control" required>
                <div class="valid-feedback">Password looks good!</div>
                <div class="invalid-feedback">Please provide a valid password.</div>
            </div>
            
            <button type="submit" class="btn login-btn">
                <i class="fa-solid fa-sign-in-alt"></i> Login to Wanderlust
            </button>
        </form>
        
        <div class="forgot-password">
            <a href="/forgot-password">
                <i class="fa-solid fa-question-circle"></i> Forgot your password?
            </a>
        </div>
        
        <div class="signup-link">
            Don't have an account? <a href="/signup">Sign up here</a>
        </div>
    </div>
</div>