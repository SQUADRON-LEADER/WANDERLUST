<% layout("/layouts/boilerplate") %>

<style>
.reset-container {
    background: #ffffff;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: -20px -15px;
    padding: 20px;
}

.reset-card {
    background: #ffffff;
    border-radius: 15px;
    padding: 40px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    border: 1px solid #e9ecef;
    max-width: 500px;
    width: 100%;
    text-align: center;
}

.success-icon {
    font-size: 4rem;
    color: #00b894;
    margin-bottom: 20px;
}

.reset-header h3 {
    color: #2c3e50;
    font-weight: 700;
    margin-bottom: 15px;
    font-size: 2rem;
}

.reset-header p {
    color: #6c757d;
    margin-bottom: 30px;
    font-size: 1.1rem;
}

.credentials-box {
    background: #f8f9fa;
    border: 1px solid #e9ecef;
    border-radius: 12px;
    padding: 25px;
    margin-bottom: 25px;
    text-align: left;
}

.credentials-box h5 {
    color: #00b894;
    font-weight: 700;
    margin-bottom: 15px;
    text-align: center;
}

.credential-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid #e9ecef;
    margin-bottom: 10px;
}

.credential-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
}

.credential-label {
    font-weight: 600;
    color: #2c3e50;
}

.credential-value {
    color: #00b894;
    font-weight: 700;
    font-family: 'Courier New', monospace;
    background: #ffffff;
    padding: 5px 10px;
    border-radius: 5px;
    border: 1px solid #e9ecef;
}

.action-buttons {
    display: flex;
    gap: 15px;
    margin-top: 25px;
}

.login-btn, .home-btn {
    flex: 1;
    border: none;
    border-radius: 8px;
    padding: 12px 24px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: all 0.3s ease;
}

.login-btn {
    background: #00b894;
    color: white;
}

.login-btn:hover {
    background: #00a085;
    transform: translateY(-1px);
    color: white;
}

.home-btn {
    background: transparent;
    color: #6c757d;
    border: 1px solid #dee2e6;
}

.home-btn:hover {
    background: #f8f9fa;
    color: #495057;
    text-decoration: none;
}

.password-hints {
    background: #fff3cd;
    border: 1px solid #ffeaa7;
    border-radius: 8px;
    padding: 15px;
    margin: 15px 0;
    text-align: left;
}

.password-hints h6 {
    color: #856404;
    font-weight: 600;
    margin-bottom: 10px;
}

.password-hints ul {
    margin: 0;
    padding-left: 20px;
    color: #856404;
}

.password-hints li {
    margin-bottom: 5px;
    font-size: 0.9rem;
}

@media (max-width: 576px) {
    .reset-card {
        margin: 20px;
        padding: 30px 20px;
    }
    
    .action-buttons {
        flex-direction: column;
    }
    
    .credential-item {
        flex-direction: column;
        align-items: flex-start;
        gap: 5px;
    }
}
</style>

<div class="reset-container">
    <div class="reset-card">
        <div class="success-icon">
            <i class="fa-solid fa-user-check"></i>
        </div>
        
        <div class="reset-header">
            <h3>Account Found!</h3>
            <p>Here are the details for user: <strong><%= username %></strong></p>
        </div>
        
        <div class="credentials-box">
            <h5><i class="fa-solid fa-key"></i> Account Information</h5>
            
            <div class="credential-item">
                <span class="credential-label">Username:</span>
                <span class="credential-value"><%= user.username %></span>
            </div>
            
            <div class="credential-item">
                <span class="credential-label">Email:</span>
                <span class="credential-value"><%= user.email %></span>
            </div>
            
            <div class="credential-item">
                <span class="credential-label">Account Status:</span>
                <span class="credential-value">Active</span>
            </div>
        </div>
        
        <div class="password-hints">
            <h6><i class="fa-solid fa-lightbulb"></i> Password Recovery Tips:</h6>
            <ul>
                <li>Try <strong>password123</strong> (most common default)</li>
                <li>Try <strong>123456</strong> or just <strong>password</strong></li>
                <li>Try your username + "123" (e.g., if username is "john", try "john123")</li>
                <li>Try your name + current year (e.g., "john2025")</li>
                <li>Check if you used any memorable dates or names</li>
            </ul>
        </div>
        
        <div style="background: #d1ecf1; padding: 15px; border-radius: 8px; margin: 15px 0; border-left: 4px solid #bee5eb;">
            <p style="margin: 0; color: #0c5460; font-size: 0.9rem;">
                <i class="fa-solid fa-info-circle"></i> <strong>Demo Note:</strong> 
                This is a demo application, so we're showing account details directly. 
                In a real app, you would receive a secure password reset link via email.
            </p>
        </div>
        
        <div class="action-buttons">
            <a href="/login" class="login-btn">
                <i class="fa-solid fa-sign-in-alt"></i> Try Login Again
            </a>
            <a href="/listings" class="home-btn">
                <i class="fa-solid fa-home"></i> Go Home
            </a>
        </div>
    </div>
</div>
