<style>
  .search-btn{
    background-color: #fe424d;
    color: white;
    border: none;
    border-radius: 25px;
    padding: 0.5rem 1rem;
    white-space: nowrap;
  }
  .search-btn:hover {
    background-color: #e03e47;
    color: white;
    border: none;
  }
  .search-btn i {
    margin-right: 0.5rem;
    display: inline;
  }
  .search-inp{
    border-radius: 25px;
    padding: 0.5rem 1rem 0.5rem 2.5rem;
    font-size: 0.9rem;
    border: 1px solid #ddd;
    min-width: 250px;
    position: relative;
  }
  .search-inp:focus {
    border-color: #fe424d;
    box-shadow: 0 0 0 0.2rem rgba(254, 66, 77, 0.25);
  }
  
  .search-container {
    position: relative;
    display: flex;
    align-items: center;
  }
  
  .search-icon {
    position: absolute;
    left: 12px;
    z-index: 10;
    color: #666;
    cursor: pointer;
    transition: color 0.3s ease;
  }
  
  .search-icon:hover {
    color: #fe424d;
  }
  
  @media (max-width: 768px) {
    .search-inp {
      min-width: 200px;
    }
  }
</style>


<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold text-primary" href="/listings" style="font-size: 1.5rem; color: #fe424d !important;">Wanderlust</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <!-- Search Form - Centered -->
      <div class="navbar-nav mx-auto">
        <form class="d-flex" method="GET" action="/listings" id="searchForm">
            <div class="search-container">
                <i class="fas fa-search search-icon" onclick="document.getElementById('searchForm').submit();"></i>
                <input class="form-control search-inp" type="search" name="search" placeholder="Search destinations..." aria-label="Search" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
            </div>
            <button class="btn search-btn ms-2" type="submit">
                <i class="fas fa-search"></i>Search
            </button>
        </form>
      </div>

      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new"> Wanderlust Your Home</a>

        <% if(!currUser) {%>
        <a class="nav-link " aria-current="page" href="/signup"><b>Sign up</b></a>
        <a class="nav-link" href="/login"><b>Log in</b></a>
        <% } %>
        <% if(currUser) {%>
        <a class="nav-link" href="/logout">Logout<b></b></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>